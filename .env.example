# ==============================================================================
# GOLD INTELLIGENCE FRAMEWORK - ENVIRONMENT CONFIGURATION
# ==============================================================================

# --- 1. CORE PIPELINE MODE ---
# Options: 'local' (uses DuckDB) | 'prod' (uses GCP BigQuery/GCS)
ENVIRONMENT=local

# Path to the local DuckDB database (used if ENVIRONMENT=local)
DUCKDB_PATH=gold_dbt/data/gold_market.duckdb

# --- 2. dbt CONFIGURATION ---
# 'dev' points to DuckDB (local) | 'prod' points to BigQuery (GCP)
# This controls which target in 'gold_dbt/profiles.yml' is used.
DBT_TARGET=dev

# --- 3. GOOGLE CLOUD SETTINGS (Required if ENVIRONMENT=prod) ---
# These must match the values used in infrastructure/terraform/
GCP_PROJECT_ID=your-gcp-project-id
GCP_DATASET=gold_analytics

# The bucket name follows the pattern: [GCP_PROJECT_ID]-gold-bronze
GCS_BUCKET_NAME=your-gcp-project-id-gold-bronze

# Path to the Service Account JSON key (Create this after 'terraform apply')
# Default location is the 'auth/' directory in the project root.
GCP_KEYFILE_PATH=auth/service_account.json

# --- 4. AIRFLOW ORCHESTRATION ---
# If AIRFLOW_PASSWORD is left empty, Airflow will auto-generate a secure 
# password on first start. Retrieve it via logs:
# docker logs data_engineering_project-airflow-1 | grep "Password for user 'admin':"
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=
